            "parse": true,
            "mempool_workers": 8,
            "mempool_sub_workers": 2,
            "block_addresses_to_keep": 600,
            "additional_params": {
                "DisableMempoolSync": true,
                "queryBackendOnMempoolResync": false
            }
        }
    },
    "meta": {
